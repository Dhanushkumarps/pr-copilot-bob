# IBM watsonx.ai Configuration
# Get your API key from: https://cloud.ibm.com/iam/apikeys
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here

# Get your project ID from watsonx.ai project settings
IBM_WATSONX_PROJECT_ID=your_watsonx_project_id_here

# IBM watsonx.ai API endpoint (default: US South region)
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Granite Model Configuration
# Available models: ibm/granite-13b-chat-v2, ibm/granite-20b-code-instruct
GRANITE_MODEL_ID=ibm/granite-13b-chat-v2

# Maximum tokens for AI generation (default: 2048)
GRANITE_MAX_TOKENS=2048

# Temperature for AI generation (0.0-1.0, default: 0.7)
# Lower = more focused, Higher = more creative
GRANITE_TEMPERATURE=0.7

# Top P for nucleus sampling (0.0-1.0, default: 0.95)
GRANITE_TOP_P=0.95

# Security Scanner Configuration
# Enable/disable security scanning (default: true)
SECURITY_SCAN_ENABLED=true

# Minimum severity to report (LOW, MEDIUM, HIGH)
SECURITY_MIN_SEVERITY=MEDIUM

# Risk Assessment Configuration
# Risk score thresholds (0-100)
RISK_THRESHOLD_HIGH=75
RISK_THRESHOLD_MEDIUM=40

# Risk factor weights (must sum to 1.0)
RISK_WEIGHT_SECURITY=0.40
RISK_WEIGHT_COMPLEXITY=0.30
RISK_WEIGHT_CHANGE_SIZE=0.15
RISK_WEIGHT_CRITICAL_FILES=0.15

# Logging Configuration
# Log level: ERROR, WARN, INFO, DEBUG (default: INFO)
LOG_LEVEL=INFO

# Log file path (relative to project root)
LOG_FILE=./logs/pr-copilot.log

# Enable console logging (default: true)
LOG_CONSOLE=true

# Enable file logging (default: true)
LOG_FILE_ENABLED=true

# Git Configuration
# Default branch to compare against (default: main)
GIT_DEFAULT_BRANCH=main

# Maximum diff size to analyze (in lines, default: 10000)
GIT_MAX_DIFF_LINES=10000

# Performance Configuration
# Timeout for AI API calls (in milliseconds, default: 30000)
AI_TIMEOUT_MS=30000

# Maximum retries for failed API calls (default: 3)
AI_MAX_RETRIES=3

# Retry delay in milliseconds (default: 1000)
AI_RETRY_DELAY_MS=1000

# Feature Flags
# Enable test suggestion generation (default: true)
FEATURE_TEST_SUGGESTIONS=true

# Enable code snippet generation in tests (default: true)
FEATURE_TEST_CODE_SNIPPETS=true

# Enable PR description generation (default: true)
FEATURE_PR_DESCRIPTION=true

# Enable risk assessment (default: true)
FEATURE_RISK_ASSESSMENT=true

# Output Configuration
# Include emojis in output (default: true)
OUTPUT_EMOJIS=true

# Include color in console output (default: true)
OUTPUT_COLORS=true

# Maximum length for PR title (default: 72)
OUTPUT_MAX_TITLE_LENGTH=72